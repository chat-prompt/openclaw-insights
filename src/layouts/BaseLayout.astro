---
interface Props { title: string; }
const { title } = Astro.props;

// 사이트 전체 마스터 토큰 (SHA-256 해시로 변환)
const SITE_TOKEN = 'openclaw-duckhu-2026';
const encoder = new TextEncoder();
const data = encoder.encode(SITE_TOKEN);
const hashBuffer = await crypto.subtle.digest('SHA-256', data);
const siteTokenHash = Array.from(new Uint8Array(hashBuffer)).map(b => b.toString(16).padStart(2, '0')).join('');
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — 오픈클로 덕후방 인사이트</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://cdn.jsdelivr.net" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" />
  <script is:inline>
    (function() {
      const saved = localStorage.getItem('theme');
      if (saved === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
    })();
  </script>
</head>
<body>
  <!-- 사이트 전체 잠금 게이트 -->
  <div id="site-gate" data-site-hash={siteTokenHash}>
    <div class="site-gate-overlay">
      <div class="site-gate-card">
        <div class="site-gate-icon">🔒</div>
        <h1>오픈클로 덕후방 인사이트</h1>
        <p>비공개 사이트입니다.</p>
        <p class="site-gate-hint">공유받은 링크로 접속하거나, 접근 코드를 입력해주세요.</p>
        <form id="site-gate-form" class="site-gate-form">
          <input type="text" id="site-gate-input" placeholder="접근 코드 입력" autocomplete="off" />
          <button type="submit">입장</button>
        </form>
        <p id="site-gate-error" class="site-gate-error" style="display:none;">접근 코드가 맞지 않아요 😿</p>
      </div>
    </div>
  </div>

  <!-- 실제 사이트 콘텐츠 (잠금 해제 시 표시) -->
  <div id="site-content" style="display:none;">
    <nav class="top-nav">
      <a href="/" class="nav-home">🔍 덕후방 인사이트</a>
      <div class="nav-links">
        <a href="/#reports" class="nav-link">📋 보고서</a>
        <button class="theme-toggle" id="theme-toggle" aria-label="테마 전환">🌙</button>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <p>GPTers 오픈클로 플랫폼팀</p>
    </footer>
  </div>

  <script is:inline>
    // 사이트 전체 잠금 로직
    (function() {
      var gate = document.getElementById('site-gate');
      var content = document.getElementById('site-content');
      var expectedHash = gate.dataset.siteHash;

      function unlock() {
        gate.style.display = 'none';
        content.style.display = '';
      }

      async function hashToken(token) {
        var encoder = new TextEncoder();
        var data = encoder.encode(token);
        var buf = await crypto.subtle.digest('SHA-256', data);
        return Array.from(new Uint8Array(buf)).map(function(b) { return b.toString(16).padStart(2, '0'); }).join('');
      }

      async function tryToken(token, save) {
        var h = await hashToken(token);
        if (h === expectedHash) {
          if (save) localStorage.setItem('site-access-token', token);
          unlock();
          return true;
        }
        return false;
      }

      // 1) URL ?site_token= 파라미터
      var params = new URLSearchParams(window.location.search);
      var urlToken = params.get('site_token');
      if (urlToken) {
        tryToken(urlToken, true).then(function(ok) {
          if (ok) {
            // site_token만 제거, 다른 파라미터(token 등)는 유지
            params.delete('site_token');
            var remaining = params.toString();
            var clean = window.location.pathname + (remaining ? '?' + remaining : '');
            window.history.replaceState({}, '', clean);
          } else {
            initForm();
          }
        });
        return;
      }

      // 2) localStorage 체크
      var saved = localStorage.getItem('site-access-token');
      if (saved) {
        tryToken(saved, false).then(function(ok) {
          if (!ok) {
            localStorage.removeItem('site-access-token');
            initForm();
          }
        });
        return;
      }

      // 3) 수동 입력
      initForm();

      function initForm() {
        var form = document.getElementById('site-gate-form');
        var input = document.getElementById('site-gate-input');
        var error = document.getElementById('site-gate-error');
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          var val = input.value.trim();
          tryToken(val, true).then(function(ok) {
            if (!ok) {
              error.style.display = '';
              input.classList.add('shake');
              setTimeout(function() { input.classList.remove('shake'); }, 500);
            }
          });
        });
      }
    })();

    // 테마 토글
    (function() {
      // site-content가 hidden일 수 있으므로 MutationObserver로 대기
      function initTheme() {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        function update() {
          var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
          btn.textContent = isDark ? '☀️' : '🌙';
        }
        update();
        btn.addEventListener('click', function() {
          var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
          if (isDark) {
            document.documentElement.removeAttribute('data-theme');
            localStorage.setItem('theme', 'light');
          } else {
            document.documentElement.setAttribute('data-theme', 'dark');
            localStorage.setItem('theme', 'dark');
          }
          update();
        });
      }
      initTheme();
    })();
  </script>
</body>
</html>

<style is:global>
  :root {
    --bg: #F5F3EE;
    --bg-card: #FFFDF9;
    --border-card: #DDD8CE;
    --text-primary: #1A2332;
    --text-secondary: #4A5568;
    --text-muted: #6B7A8F;
    --accent: #f59e0b;
    --accent-bg: rgba(245, 158, 11, 0.1);
    --header-bg: rgba(245, 243, 238, 0.85);
    color-scheme: light;
  }

  [data-theme="dark"] {
    --bg: #1E2028;
    --bg-card: #262830;
    --border-card: #3A3D48;
    --text-primary: #E8EAED;
    --text-secondary: #B0B8C4;
    --text-muted: #7B8698;
    --accent: #FBBF24;
    --accent-bg: rgba(251, 191, 36, 0.12);
    --header-bg: rgba(30, 32, 40, 0.85);
    color-scheme: dark;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: var(--bg);
    color: var(--text-primary);
    font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, sans-serif;
    line-height: 1.7;
    transition: background 0.3s ease, color 0.3s ease;
  }
  .top-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 24px;
    border-bottom: 1px solid var(--border-card);
    background: var(--header-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .nav-home { color: var(--accent); text-decoration: none; font-weight: 700; font-size: 17px; }
  .nav-links { display: flex; align-items: center; gap: 12px; }
  .nav-link { color: var(--text-secondary); text-decoration: none; font-size: 14px; font-weight: 600; transition: color 0.2s; }
  .nav-link:hover { color: var(--accent); }
  .theme-toggle {
    background: none;
    border: 1px solid var(--border-card);
    border-radius: 8px;
    padding: 6px 10px;
    cursor: pointer;
    font-size: 18px;
    line-height: 1;
    transition: all 0.2s;
    color: var(--text-muted);
  }
  .theme-toggle:hover { border-color: var(--accent); background: var(--accent-bg); }

  main { max-width: 800px; margin: 0 auto; padding: 0 24px 80px; }
  footer { text-align: center; padding: 24px; color: var(--text-muted); font-size: 12px; border-top: 1px solid var(--border-card); }
  a { color: var(--accent); }

  .back-to-list { margin-bottom: 24px; padding-top: 24px; }
  .back-to-list a { color: var(--text-secondary); text-decoration: none; font-size: 14px; }
  .back-to-list a:hover { color: var(--accent); }

  article { padding-top: 16px; }
  .article-header { margin-bottom: 32px; }
  .article-header h1 { font-size: 32px; font-weight: 700; line-height: 1.3; margin-top: 8px; }
  .series-badge { font-size: 13px; color: var(--accent); font-weight: 600; }
  .meta { margin-top: 8px; font-size: 13px; color: var(--text-muted); }

  .article-body { font-size: 17.5px; line-height: 1.8; }
  .article-body h1 { display: none; }
  .article-body h2 { font-size: 24px; margin: 32px 0 12px; padding-bottom: 6px; border-bottom: 1px solid var(--border-card); }
  .article-body h3 { font-size: 20px; margin: 24px 0 8px; }
  .article-body p { margin-bottom: 16px; color: var(--text-secondary); }
  .article-body ul, .article-body ol { margin-bottom: 16px; padding-left: 24px; color: var(--text-secondary); }
  .article-body li { margin-bottom: 4px; }
  .article-body blockquote { border-left: 3px solid var(--accent); padding: 8px 16px; margin: 16px 0; color: var(--text-secondary); background: var(--accent-bg); border-radius: 0 8px 8px 0; }
  .article-body code { background: var(--bg-card); padding: 2px 6px; border-radius: 4px; font-size: 14px; }
  .article-body pre { background: #1A2332; color: #E4E9ED; padding: 16px; border-radius: 8px; overflow-x: auto; margin-bottom: 16px; }
  [data-theme="dark"] .article-body pre { background: #14161C; }
  .article-body table { width: 100%; border-collapse: collapse; margin-bottom: 16px; }
  .article-body th, .article-body td { padding: 10px 14px; border: 1px solid var(--border-card); text-align: left; font-size: 15px; }
  .article-body th { background: var(--bg-card); font-weight: 600; }
  .article-body strong { color: var(--text-primary); }

  /* 사이트 전체 잠금 게이트 */
  .site-gate-overlay {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
  }
  .site-gate-card {
    text-align: center;
    padding: 56px 48px;
    background: var(--bg-card);
    border: 1px solid var(--border-card);
    border-radius: 20px;
    max-width: 440px;
    width: 90%;
    box-shadow: 0 8px 40px rgba(0,0,0,0.06);
  }
  .site-gate-icon { font-size: 56px; margin-bottom: 20px; }
  .site-gate-card h1 { font-size: 24px; font-weight: 700; margin-bottom: 12px; }
  .site-gate-card p { font-size: 15px; color: var(--text-secondary); line-height: 1.6; }
  .site-gate-hint { margin-top: 4px; font-size: 13px; color: var(--text-muted); }
  .site-gate-form {
    display: flex;
    gap: 8px;
    margin-top: 28px;
    justify-content: center;
  }
  .site-gate-form input {
    padding: 12px 18px;
    border: 1px solid var(--border-card);
    border-radius: 10px;
    font-size: 15px;
    background: var(--bg);
    color: var(--text-primary);
    width: 220px;
    outline: none;
    transition: border-color 0.2s;
  }
  .site-gate-form input:focus { border-color: var(--accent); }
  .site-gate-form button {
    padding: 12px 24px;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .site-gate-form button:hover { opacity: 0.9; }
  .site-gate-error { color: #ef4444; font-size: 14px; margin-top: 14px; }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    20%, 60% { transform: translateX(-6px); }
    40%, 80% { transform: translateX(6px); }
  }
  .shake { animation: shake 0.4s; }
</style>
