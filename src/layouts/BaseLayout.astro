---
interface Props { title: string; }
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — 오픈클로 덕후방 인사이트</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <nav class="top-nav">
    <a href="/" class="nav-home">🔍 덕후방 인사이트</a>
  </nav>
  <main>
    <slot />
  </main>
  <footer>
    <p>GPTers 오픈클로 플랫폼팀</p>
  </footer>
</body>
</html>

<style is:global>
  :root {
    --bg: #0f1117;
    --bg-card: #1a1d27;
    --border-card: #2a2d3a;
    --text-primary: #e8eaed;
    --text-secondary: #9aa0a6;
    --text-muted: #6b7280;
    --accent: #f59e0b;
    --accent-bg: rgba(245, 158, 11, 0.12);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: var(--bg); color: var(--text-primary); font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; line-height: 1.7; }
  .top-nav { padding: 16px 24px; border-bottom: 1px solid var(--border-card); }
  .nav-home { color: var(--accent); text-decoration: none; font-weight: 700; font-size: 16px; }
  main { max-width: 800px; margin: 0 auto; padding: 0 24px 80px; }
  footer { text-align: center; padding: 24px; color: var(--text-muted); font-size: 12px; border-top: 1px solid var(--border-card); }
  a { color: var(--accent); }

  .back-to-list { margin-bottom: 24px; padding-top: 24px; }
  .back-to-list a { color: var(--text-secondary); text-decoration: none; font-size: 14px; }
  .back-to-list a:hover { color: var(--accent); }

  article { padding-top: 16px; }
  .article-header { margin-bottom: 32px; }
  .article-header h1 { font-size: 28px; font-weight: 700; line-height: 1.3; margin-top: 8px; }
  .series-badge { font-size: 13px; color: var(--accent); font-weight: 600; }
  .meta { margin-top: 8px; font-size: 13px; color: var(--text-muted); }

  .article-body { font-size: 16px; line-height: 1.8; }
  .article-body h2 { font-size: 22px; margin: 32px 0 12px; padding-bottom: 6px; border-bottom: 1px solid var(--border-card); }
  .article-body h3 { font-size: 18px; margin: 24px 0 8px; }
  .article-body p { margin-bottom: 16px; color: var(--text-secondary); }
  .article-body ul, .article-body ol { margin-bottom: 16px; padding-left: 24px; color: var(--text-secondary); }
  .article-body li { margin-bottom: 4px; }
  .article-body blockquote { border-left: 3px solid var(--accent); padding: 8px 16px; margin: 16px 0; color: var(--text-secondary); background: var(--accent-bg); border-radius: 0 8px 8px 0; }
  .article-body code { background: var(--bg-card); padding: 2px 6px; border-radius: 4px; font-size: 14px; }
  .article-body pre { background: var(--bg-card); padding: 16px; border-radius: 8px; overflow-x: auto; margin-bottom: 16px; }
  .article-body table { width: 100%; border-collapse: collapse; margin-bottom: 16px; }
  .article-body th, .article-body td { padding: 8px 12px; border: 1px solid var(--border-card); text-align: left; font-size: 14px; }
  .article-body th { background: var(--bg-card); font-weight: 600; }
  .article-body strong { color: var(--text-primary); }
</style>
